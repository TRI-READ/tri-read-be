# Local database defaults from compose.db.yaml
DATABASE_URL=jdbc:postgresql://localhost:15432/tri_read
POSTGRES_USER=tri_read_app
POSTGRES_PASSWORD=tri_read_dev

# Automated quiz generation
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_VALIDATION_MODEL=gemini-2.5-flash
QUIZ_PROMPT_VERSION=v1
QUIZ_GENERATION_ENABLED=false
QUIZ_AUTO_PUBLISH=false
QUIZ_GENERATION_MAX_ATTEMPTS=3
QUIZ_VALIDATION_PASS_SCORE=90
QUIZ_GENERATION_CRON=0 0 3 * * SUN
