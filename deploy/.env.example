# Use :80 until a domain is connected. Replace it with the domain for HTTPS.
SITE_DOMAIN=:80
POSTGRES_DB=tri_read
POSTGRES_USER=tri_read_app
POSTGRES_PASSWORD=change-me
DATABASE_URL=jdbc:postgresql://db:5432/tri_read

GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-3.1-flash-lite
GEMINI_VALIDATION_MODEL=gemini-3.1-flash-lite
QUIZ_PROMPT_VERSION=v1
QUIZ_GENERATION_ENABLED=false
QUIZ_AUTO_PUBLISH=false
QUIZ_GENERATION_MAX_ATTEMPTS=3
QUIZ_GENERATION_RETRY_DELAY_MS=10000
QUIZ_VALIDATION_PASS_SCORE=90
QUIZ_VARIANTS_PER_DATE=3
QUIZ_GENERATION_CRON=0 10 3 * * *
